      <bpmn:incoming>sequenceFlow_8</bpmn:incoming>
      <bpmn:outgoing>sequenceFlow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:inclusiveGateway id="inclusiveGateway_1" name="">
