<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="0a0ba04" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.6.0" camunda:diagramRelationId="331d01c6-770f-4b16-8799-536a997ca928">
  <bpmn:collaboration id="Collaboration_EventRegistration">
    <bpmn:participant id="Participant_EventRegistration" name="Event team" processRef="Process_EventRegistration-1u9wzht" />
    <bpmn:participant id="Participant_1wawa2o" name="Attendee" />
    <bpmn:messageFlow id="Flow_1p4u8s4" sourceRef="Participant_1wawa2o" targetRef="StartEvent_Form" />
    <bpmn:messageFlow id="Flow_0belkav" sourceRef="Activity_NotifyAttendee" targetRef="Participant_1wawa2o" />
  </bpmn:collaboration>
  <bpmn:process id="Process_EventRegistration-1u9wzht" name="Event Registration" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:sequenceFlow id="Flow_15hhweo" sourceRef="StartEvent_Form" targetRef="Activity_StoreRegistrations" />
    <bpmn:startEvent id="StartEvent_Form" name="Event registration received">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="camundaModeler:exampleOutputJson" value="{&#10;  &#34;first_name&#34;: &#34;John&#34;,&#10;  &#34;last_name&#34;: &#34;Doe&#34;,&#10;  &#34;email&#34;: &#34;john.doe@acme.com&#34;,&#10;  &#34;phone_number&#34;: &#34;&#34;,&#10;  &#34;company&#34;: &#34;Acme Corp&#34;,&#10;  &#34;news_source&#34;: [&#10;    &#34;website&#34;,&#10;    &#34;google&#34;&#10;  ],&#10;  &#34;news_source_alternative&#34;: &#34;&#34;,&#10;  &#34;additional_comments&#34;: &#34;&#34;,&#10;  &#34;future_notifications&#34;: true&#10;}" />
          <zeebe:property name="publicAccess" value="true" />
        </zeebe:properties>
        <zeebe:ioMapping>
          <zeebe:output source="=first_name" target="first_name" />
          <zeebe:output source="=last_name" target="last_name" />
          <zeebe:output source="=email" target="email" />
          <zeebe:output source="=phone_number" target="phone_number" />
          <zeebe:output source="=company" target="company" />
          <zeebe:output source="=concatenate(news_source, [news_source_alternative])" target="news_source" />
          <zeebe:output source="=additional_comments" target="additional_comments" />
          <zeebe:output source="=future_notifications" target="future_notifications" />
        </zeebe:ioMapping>
        <zeebe:formDefinition formId="EventRegistration" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_15hhweo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_05vjl7d" sourceRef="Activity_NotifyAttendee" targetRef="Gateway_0u6owc4" />
    <bpmn:sequenceFlow id="Flow_06htesz" sourceRef="Activity_StoreRegistrations" targetRef="Activity_NotifyAttendee" />
    <bpmn:sequenceFlow id="Flow_1pjwdwi" name="Opt-In" sourceRef="Gateway_0u6owc4" targetRef="Activity_AddToNewsletter">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=future_notifications</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_05qqgi8" sourceRef="Activity_AddToNewsletter" targetRef="Gateway_0k2t6ga" />
    <bpmn:sequenceFlow id="Flow_1n8iwqt" sourceRef="Gateway_0k2t6ga" targetRef="Event_0kitru1" />
    <bpmn:sequenceFlow id="Flow_0j25dn6" name="No opt-in" sourceRef="Gateway_0u6owc4" targetRef="Gateway_0k2t6ga" />
    <bpmn:dataStoreReference id="DataStoreReference_1s94j66" name="Newsletter system" />
    <bpmn:serviceTask id="Activity_StoreRegistrations" name="Store registration in Google Sheets" zeebe:modelerTemplate="io.camunda.connectors.GoogleSheets.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:google-sheets:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bearer" target="authentication.authType" />
          <zeebe:input source="&#60;YOUR TOKEN&#62;" target="authentication.bearerToken" />
          <zeebe:input source="createRow" target="operation.type" />
          <zeebe:input source="&#60;YOUR SPREADSHEET ID&#62;" target="operation.spreadsheetId" />
          <zeebe:input source="worksheetname" target="operation.worksheetName" />
          <zeebe:input source="2" target="operation.rowIndex" />
          <zeebe:input source="=[first_name, last_name, email, phone_number, company, news_source, future_notifications]" target="operation.values" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15hhweo</bpmn:incoming>
      <bpmn:outgoing>Flow_06htesz</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_NotifyAttendee" name="Notify attendee of successful registration" zeebe:modelerTemplate="io.camunda.connectors.SendGrid.v2" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendgrid:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="&#60;YOUR API KEY&#62;" target="apiKey" />
          <zeebe:input source="&#60;YOUR NAME&#62;" target="from.name" />
          <zeebe:input source="&#60;YOUR EMAIL&#62;" target="from.email" />
          <zeebe:input source="=first_name + &#34; &#34; + last_name" target="to.name" />
          <zeebe:input source="=email" target="to.email" />
          <zeebe:input source="mail" target="unMappedFieldNotUseInModel.mailType" />
          <zeebe:input source="You are registered!" target="content.subject" />
          <zeebe:input source="text/plain" target="content.type" />
          <zeebe:input source="We confirm your registration to our event. Looking forward to see you soon!" target="content.value" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_06htesz</bpmn:incoming>
      <bpmn:outgoing>Flow_05vjl7d</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0u6owc4" name="Opt-In to future notifications?" default="Flow_0j25dn6">
      <bpmn:incoming>Flow_05vjl7d</bpmn:incoming>
      <bpmn:outgoing>Flow_1pjwdwi</bpmn:outgoing>
      <bpmn:outgoing>Flow_0j25dn6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_AddToNewsletter" name="Add to newsletter list">
      <bpmn:incoming>Flow_1pjwdwi</bpmn:incoming>
      <bpmn:outgoing>Flow_05qqgi8</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1df2u8n">
        <bpmn:targetRef>DataStoreReference_1s94j66</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_0k2t6ga">
      <bpmn:incoming>Flow_05qqgi8</bpmn:incoming>
      <bpmn:incoming>Flow_0j25dn6</bpmn:incoming>
      <bpmn:outgoing>Flow_1n8iwqt</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_0kitru1" name="Attendee registered">
      <bpmn:incoming>Flow_1n8iwqt</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="TextAnnotation_event_reg_intro">
      <bpmn:text>Triggered when an attendee submits an event registration form. The happy-path outcome is the attendee confirmed, optionally added to the newsletter, and notified by email.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_event_reg_intro" associationDirection="None" sourceRef="StartEvent_Form" targetRef="TextAnnotation_event_reg_intro" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Collaboration_EventRegistration">
    <bpmndi:BPMNPlane id="BPMNPlane_Collaboration_EventRegistration" bpmnElement="Collaboration_EventRegistration">
      <bpmndi:BPMNShape id="BPMNShape_Participant_EventRegistration" bpmnElement="Participant_EventRegistration" isHorizontal="true">
        <dc:Bounds x="340" y="220" width="1152" height="320" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Participant_1wawa2o" bpmnElement="Participant_1wawa2o" isHorizontal="true">
        <dc:Bounds x="368" y="80" width="428" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1p4u8s4" bpmnElement="Flow_1p4u8s4">
        <di:waypoint x="398" y="140" />
        <di:waypoint x="398" y="282" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_0belkav" bpmnElement="Flow_0belkav">
        <di:waypoint x="766" y="260" />
        <di:waypoint x="766" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_Form" bpmnElement="StartEvent_Form">
        <dc:Bounds x="380" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_StoreRegistrations" bpmnElement="Activity_StoreRegistrations">
        <dc:Bounds x="516" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_NotifyAttendee" bpmnElement="Activity_NotifyAttendee">
        <dc:Bounds x="716" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_0u6owc4" bpmnElement="Gateway_0u6owc4" isMarkerVisible="true">
        <dc:Bounds x="916" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_AddToNewsletter" bpmnElement="Activity_AddToNewsletter">
        <dc:Bounds x="1066" y="420" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_0k2t6ga" bpmnElement="Gateway_0k2t6ga" isMarkerVisible="true">
        <dc:Bounds x="1266" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Event_0kitru1" bpmnElement="Event_0kitru1">
        <dc:Bounds x="1416" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_TextAnnotation_event_reg_intro" bpmnElement="TextAnnotation_event_reg_intro">
        <dc:Bounds x="80" y="255" width="260" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_DataStoreReference_1s94j66" bpmnElement="DataStoreReference_1s94j66">
        <dc:Bounds x="1091" y="350" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_15hhweo" bpmnElement="Flow_15hhweo">
        <di:waypoint x="416" y="300" />
        <di:waypoint x="516" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_05vjl7d" bpmnElement="Flow_05vjl7d">
        <di:waypoint x="816" y="300" />
        <di:waypoint x="916" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_06htesz" bpmnElement="Flow_06htesz">
        <di:waypoint x="616" y="300" />
        <di:waypoint x="716" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1n8iwqt" bpmnElement="Flow_1n8iwqt">
        <di:waypoint x="1316" y="300" />
        <di:waypoint x="1416" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_0j25dn6" bpmnElement="Flow_0j25dn6">
        <di:waypoint x="966" y="300" />
        <di:waypoint x="1266" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1pjwdwi" bpmnElement="Flow_1pjwdwi">
        <di:waypoint x="941" y="325" />
        <di:waypoint x="941" y="460" />
        <di:waypoint x="1066" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_05qqgi8" bpmnElement="Flow_05qqgi8">
        <di:waypoint x="1166" y="460" />
        <di:waypoint x="1291" y="460" />
        <di:waypoint x="1291" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Association_event_reg_intro" bpmnElement="Association_event_reg_intro">
        <di:waypoint x="380" y="300" />
        <di:waypoint x="340" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_DataOutputAssociation_1df2u8n" bpmnElement="DataOutputAssociation_1df2u8n">
        <di:waypoint x="1116" y="420" />
        <di:waypoint x="1116" y="400" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
