      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_e2" bpmnElement="e2">
        <di:waypoint x="786" y="760" />
        <di:waypoint x="886" y="760" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_e1" bpmnElement="e1">
        <di:waypoint x="536" y="658" />
        <di:waypoint x="536" y="760" />
        <di:waypoint x="686" y="760" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_loop" bpmnElement="loop">
        <di:waypoint x="1222" y="400" />
        <di:waypoint x="1222" y="380" />
        <di:waypoint x="536" y="380" />
