<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Defs_fnol" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.49.0">
  <bpmn:collaboration id="Collab">
    <bpmn:participant id="Pool_Claimant" name="Policyholder" processRef="Proc_Claimant" />
    <bpmn:participant id="Pool_Carrier" name="Insurance Carrier" processRef="Proc_Carrier" />
    <bpmn:messageFlow id="mf_submit" sourceRef="Submit_Claim" targetRef="Start_K" />
    <bpmn:messageFlow id="mf_pay" sourceRef="Issue_Payment" targetRef="Await_Outcome" />
    <bpmn:messageFlow id="mf_deny" sourceRef="Send_Denial" targetRef="Await_Outcome" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Claimant" isExecutable="false">
    <bpmn:startEvent id="Start_C" name="Loss occurs">
      <bpmn:outgoing>c1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Submit_Claim" name="Submit FNOL (mobile app)">
      <bpmn:incoming>c1</bpmn:incoming>
      <bpmn:outgoing>c2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:receiveTask id="Await_Outcome" name="Await decision">
      <bpmn:incoming>c2</bpmn:incoming>
      <bpmn:outgoing>c3</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="End_C" name="Claim closed">
      <bpmn:incoming>c3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="c1" sourceRef="Start_C" targetRef="Submit_Claim" />
    <bpmn:sequenceFlow id="c2" sourceRef="Submit_Claim" targetRef="Await_Outcome" />
    <bpmn:sequenceFlow id="c3" sourceRef="Await_Outcome" targetRef="End_C" />
  </bpmn:process>
  <bpmn:process id="Proc_Carrier" isExecutable="true">
    <bpmn:documentation>Exercises a lane-constrained FNOL workflow with agentic triage, disposition branches, a feedback loop, and settlement.</bpmn:documentation>
    <bpmn:laneSet id="ls">
      <bpmn:lane id="Lane_Settle" name="Settlement">
        <bpmn:flowNodeRef>Issue_Payment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Paid</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Agent" name="AI Triage">
        <bpmn:flowNodeRef>Gw_Disp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Auto_Approve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Assign_Adjuster</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Adjuster_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Request_Info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Denial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Deny</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Escalate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Esc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Triage_Agent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>B_SLA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Intake" name="Intake">
        <bpmn:flowNodeRef>Start_K</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Extract</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_K" name="FNOL received">
      <bpmn:outgoing>k1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med1" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Extract" name="Extract claim data (Document AI)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" />
      </bpmn:extensionElements>
      <bpmn:incoming>k1</bpmn:incoming>
      <bpmn:outgoing>k2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:adHocSubProcess id="Triage_Agent" name="AI Claims Triage Agent">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" />
        <zeebe:adHoc activeElementsCollection="=toolCalls" />
      </bpmn:extensionElements>
      <bpmn:incoming>k2</bpmn:incoming>
      <bpmn:incoming>loop</bpmn:incoming>
      <bpmn:outgoing>k3</bpmn:outgoing>
      <bpmn:serviceTask id="Tool_Fraud" name="Fraud score (REST)">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Tool_Coverage" name="Coverage check (REST)">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Tool_Estimate" name="Damage estimate (REST)">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Tool_Policy" name="Policy lookup (REST)">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
    </bpmn:adHocSubProcess>
    <bpmn:exclusiveGateway id="Gw_Disp" name="Disposition?">
      <bpmn:incoming>k3</bpmn:incoming>
      <bpmn:outgoing>d_fast</bpmn:outgoing>
      <bpmn:outgoing>d_invest</bpmn:outgoing>
      <bpmn:outgoing>d_info</bpmn:outgoing>
      <bpmn:outgoing>d_deny</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Auto_Approve" name="Auto-approve payout">
      <bpmn:incoming>d_fast</bpmn:incoming>
      <bpmn:outgoing>a1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Assign_Adjuster" name="Assign adjuster">
      <bpmn:incoming>d_invest</bpmn:incoming>
      <bpmn:outgoing>a2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Adjuster_Review" name="Adjuster review">
      <bpmn:incoming>a2</bpmn:incoming>
      <bpmn:outgoing>a3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="Request_Info" name="Request more info">
      <bpmn:incoming>d_info</bpmn:incoming>
      <bpmn:outgoing>loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Send_Denial" name="Send denial">
      <bpmn:incoming>d_deny</bpmn:incoming>
      <bpmn:outgoing>dn</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Deny" name="Denied">
      <bpmn:incoming>dn</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gw_Join" name="Approved">
      <bpmn:incoming>a1</bpmn:incoming>
      <bpmn:incoming>a3</bpmn:incoming>
      <bpmn:outgoing>j1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Issue_Payment" name="Issue payment (REST)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" />
      </bpmn:extensionElements>
      <bpmn:incoming>j1</bpmn:incoming>
      <bpmn:outgoing>p1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Paid" name="Paid">
      <bpmn:incoming>p1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Escalate" name="Escalate to supervisor">
      <bpmn:incoming>e1</bpmn:incoming>
      <bpmn:outgoing>e2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Esc" name="Escalated">
      <bpmn:incoming>e2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="B_SLA" name="SLA breach" cancelActivity="false" attachedToRef="Triage_Agent">
      <bpmn:outgoing>e1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="ted1" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="k1" sourceRef="Start_K" targetRef="Extract" />
    <bpmn:sequenceFlow id="k2" sourceRef="Extract" targetRef="Triage_Agent" />
    <bpmn:sequenceFlow id="loop" sourceRef="Request_Info" targetRef="Triage_Agent" />
    <bpmn:sequenceFlow id="k3" sourceRef="Triage_Agent" targetRef="Gw_Disp" />
    <bpmn:sequenceFlow id="d_fast" name="fast-track" sourceRef="Gw_Disp" targetRef="Auto_Approve" />
    <bpmn:sequenceFlow id="d_invest" name="investigate" sourceRef="Gw_Disp" targetRef="Assign_Adjuster" />
    <bpmn:sequenceFlow id="d_info" name="need info" sourceRef="Gw_Disp" targetRef="Request_Info" />
    <bpmn:sequenceFlow id="d_deny" name="deny" sourceRef="Gw_Disp" targetRef="Send_Denial" />
    <bpmn:sequenceFlow id="a1" sourceRef="Auto_Approve" targetRef="Gw_Join" />
    <bpmn:sequenceFlow id="a2" sourceRef="Assign_Adjuster" targetRef="Adjuster_Review" />
    <bpmn:sequenceFlow id="a3" sourceRef="Adjuster_Review" targetRef="Gw_Join" />
    <bpmn:sequenceFlow id="dn" sourceRef="Send_Denial" targetRef="End_Deny" />
    <bpmn:sequenceFlow id="j1" sourceRef="Gw_Join" targetRef="Issue_Payment" />
    <bpmn:sequenceFlow id="p1" sourceRef="Issue_Payment" targetRef="End_Paid" />
    <bpmn:sequenceFlow id="e1" sourceRef="B_SLA" targetRef="Escalate" />
    <bpmn:sequenceFlow id="e2" sourceRef="Escalate" targetRef="End_Esc" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Collab">
    <bpmndi:BPMNPlane id="BPMNPlane_Collab" bpmnElement="Collab">
      <bpmndi:BPMNShape id="BPMNShape_Pool_Claimant" bpmnElement="Pool_Claimant" isHorizontal="true">
        <dc:Bounds x="1316" y="1360" width="682" height="160" />
      </bpmndi:BPMNShape>
