        <di:waypoint x="1272" y="760" />
        <di:waypoint x="1372" y="760" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_a3" bpmnElement="a3">
        <di:waypoint x="1472" y="760" />
