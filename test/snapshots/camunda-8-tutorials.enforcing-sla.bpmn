      <bpmndi:BPMNShape id="BPMNShape_ReplyNotReceivedEvent" bpmnElement="ReplyNotReceivedEvent">
        <dc:Bounds x="1314" y="121" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ReplyLoggedEvent" bpmnElement="ReplyLoggedEvent">
        <dc:Bounds x="1482" y="281" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_LogReplyTask" bpmnElement="LogReplyTask">
        <dc:Bounds x="1282" y="259" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Event_0mvom7y" bpmnElement="Event_0mvom7y">
        <dc:Bounds x="828" y="281" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_SendResponseTask" bpmnElement="SendResponseTask">
        <dc:Bounds x="796" y="99" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_RetractionReceivedEvent" bpmnElement="RetractionReceivedEvent">
        <dc:Bounds x="628" y="161" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_SLACheckEventSubprocess" bpmnElement="SLACheckEventSubprocess" isExpanded="true">
        <dc:Bounds x="460" y="419" width="452" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_TextAnnotation_1x50j3c" bpmnElement="TextAnnotation_1x50j3c">
        <dc:Bounds x="80" y="80" width="340" height="118" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_14lnez5" bpmnElement="Flow_14lnez5">
        <di:waypoint x="496" y="139" />
        <di:waypoint x="596" y="139" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_0y68b2d" bpmnElement="Flow_0y68b2d">
        <di:waypoint x="696" y="139" />
        <di:waypoint x="796" y="139" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_0wpqg90" bpmnElement="Flow_0wpqg90">
