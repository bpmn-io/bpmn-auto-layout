    <bpmn:textAnnotation id="TextAnnotation_openai_routing_intro">
      <bpmn:text>Triggered when a customer inquiry is received. The process uses OpenAI to classify and route the inquiry to the correct team; the happy-path outcome is the inquiry resolved by the appropriate team.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_openai_routing_intro" associationDirection="None" sourceRef="StartEvent_1" targetRef="TextAnnotation_openai_routing_intro" />
