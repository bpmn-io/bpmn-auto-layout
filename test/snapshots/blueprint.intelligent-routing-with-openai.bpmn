    <bpmn:sequenceFlow id="Flow_024pys7" sourceRef="Gateway_01n9u1n" targetRef="openai_call" />
    <bpmn:exclusiveGateway id="Gateway_0wwrp47" name="Inquiry resolved?">
      <bpmn:incoming>Flow_1h01n0i</bpmn:incoming>
