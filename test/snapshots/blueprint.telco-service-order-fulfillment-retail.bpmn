    <bpmn:scriptTask id="Activity_1jyklqs" name="Decompose order">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  &#34;hardwareOrders&#34;: orderItems[item.type = &#34;hardware&#34;],&#10;  &#34;mobileOrders&#34;: orderItems[item.type = &#34;mobile&#34;]&#10;}" resultVariable="decomposedOrders" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1cg0tcv</bpmn:incoming>
      <bpmn:outgoing>Flow_1o7kv0t</bpmn:outgoing>
