    <bpmn:startEvent id="Event_047t2hg" name="Service order received">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="camundaModeler:exampleOutputJson" value="{&#10;  &#34;orderId&#34;: 123,&#10;  &#34;orderItems&#34;: [&#10;    {&#10;      &#34;orderItemId&#34;: 456,&#10;      &#34;orderItemName&#34;: &#34;Internet L&#34;,&#10;      &#34;type&#34;: &#34;mobile&#34;,&#10;      &#34;price&#34;: 29.99,&#10;      &#34;reocurring&#34;: &#34;monthly&#34;&#10;    },&#10;   {&#10;      &#34;orderItemId&#34;: 368,&#10;      &#34;orderItemName&#34;: &#34;Mobile S&#34;,&#10;      &#34;type&#34;: &#34;mobile&#34;,&#10;      &#34;price&#34;: 9.99,&#10;      &#34;reocurring&#34;: &#34;monthly&#34;&#10;    },&#10;    {&#10;      &#34;orderItemId&#34;: 789,&#10;      &#34;orderItemName&#34;: &#34;Smartphone 42&#34;,&#10;      &#34;type&#34;: &#34;hardware&#34;,&#10;      &#34;price&#34;: 699.99,&#10;      &#34;reocurring&#34;: null&#10;    },&#10;    {&#10;      &#34;orderItemId&#34;: 125,&#10;      &#34;orderItemName&#34;: &#34;Laptop 66&#34;,&#10;      &#34;type&#34;: &#34;hardware&#34;,&#10;      &#34;price&#34;: 2599.99,&#10;      &#34;reocurring&#34;: null&#10;    }&#10;  ]&#10;}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_09cipqi</bpmn:outgoing>
    </bpmn:startEvent>
