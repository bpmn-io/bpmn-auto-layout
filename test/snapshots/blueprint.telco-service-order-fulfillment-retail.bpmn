    <bpmn:subProcess id="Activity_1j83yc1" name="Fraud check">
      <bpmn:incoming>Flow_09cipqi</bpmn:incoming>
      <bpmn:outgoing>Flow_1cg0tcv</bpmn:outgoing>
      <bpmn:startEvent id="Event_0ybir2v" name="fraud check requested">
        <bpmn:outgoing>Flow_04uemyu</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_04uemyu" sourceRef="Event_0ybir2v" targetRef="Activity_0hvah0z" />
      <bpmn:scriptTask id="Activity_0hvah0z" name="Calculate prices">
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  oneTimePrice: sum(orderItems[reocurring = null].price),&#10;  monthlyPrice: sum(orderItems[reocurring = &#34;monthly&#34;].price)&#10;}" resultVariable="prices" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_04uemyu</bpmn:incoming>
        <bpmn:outgoing>Flow_0mq72v1</bpmn:outgoing>
      </bpmn:scriptTask>
      <bpmn:exclusiveGateway id="Gateway_1fftndd" name="price dimensions?" default="Flow_157mh1q">
        <bpmn:incoming>Flow_0mq72v1</bpmn:incoming>
        <bpmn:outgoing>Flow_157mh1q</bpmn:outgoing>
        <bpmn:outgoing>Flow_0ecfx32</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_0mq72v1" sourceRef="Activity_0hvah0z" targetRef="Gateway_1fftndd" />
      <bpmn:endEvent id="Event_03myfov" name="no fraud check necessary">
        <bpmn:incoming>Flow_157mh1q</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_157mh1q" name="normal" sourceRef="Gateway_1fftndd" targetRef="Event_03myfov" />
      <bpmn:sequenceFlow id="Flow_0ecfx32" name="high" sourceRef="Gateway_1fftndd" targetRef="Activity_1rg0k6z">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=prices.oneTimePrice &gt; 3000 or prices.monthlyPrice &gt; 600</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:serviceTask id="Activity_1rg0k6z" name="Perform fraud check">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="perform_fraud_check" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0ecfx32</bpmn:incoming>
        <bpmn:outgoing>Flow_1havwfr</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="Event_198nlm3" name="no fraud found">
        <bpmn:incoming>Flow_1havwfr</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1havwfr" sourceRef="Activity_1rg0k6z" targetRef="Event_198nlm3" />
      <bpmn:boundaryEvent id="Event_15g4dlg" name="fraud detected" attachedToRef="Activity_1rg0k6z">
        <bpmn:outgoing>Flow_04sj3nb</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_1k8azlh" errorRef="Error_1uwy6qv" />
      </bpmn:boundaryEvent>
      <bpmn:sequenceFlow id="Flow_04sj3nb" sourceRef="Event_15g4dlg" targetRef="Event_06m1k91" />
      <bpmn:endEvent id="Event_06m1k91" name="fraud found">
        <bpmn:incoming>Flow_04sj3nb</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_1iu4q7y" errorRef="Error_0cbsxer" />
      </bpmn:endEvent>
    </bpmn:subProcess>
