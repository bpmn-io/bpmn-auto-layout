        <di:waypoint x="467" y="818" />
        <di:waypoint x="507" y="798" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="BPMNShape_Event_NextCustomerMessageReceived" bpmnElement="Event_NextCustomerMessageReceived">
        <dc:Bounds x="431" y="480" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Tool_WaitForNextMessage" bpmnElement="Tool_WaitForNextMessage" isMarkerVisible="true">
        <dc:Bounds x="256" y="473" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_ToolForwardMessageToCalculatorAgent" bpmnElement="Activity_ToolForwardMessageToCalculatorAgent">
        <dc:Bounds x="567" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Event_ReplyFromBusinessAgentReceived" bpmnElement="Event_ReplyFromBusinessAgentReceived">
        <dc:Bounds x="431" y="640" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_ToolReplyToCustomer" bpmnElement="Activity_ToolReplyToCustomer">
        <dc:Bounds x="567" y="480" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_ToolForwardMessageToTranslatorAgent" bpmnElement="Activity_ToolForwardMessageToTranslatorAgent">
        <dc:Bounds x="567" y="640" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Event_BusinessAgentFinished" bpmnElement="Event_BusinessAgentFinished">
