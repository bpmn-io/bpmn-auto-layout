      <bpmndi:BPMNEdge id="BPMNEdge_Flow_04ormsw" bpmnElement="Flow_04ormsw">
        <di:waypoint x="306" y="498" />
        <di:waypoint x="431" y="498" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_11fduhz" bpmnElement="Flow_11fduhz">
        <di:waypoint x="281" y="523" />
        <di:waypoint x="281" y="658" />
        <di:waypoint x="431" y="658" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1dyx9jy" bpmnElement="Flow_1dyx9jy">
        <di:waypoint x="281" y="473" />
        <di:waypoint x="281" y="338" />
        <di:waypoint x="431" y="338" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1suzs5x" bpmnElement="Flow_1suzs5x">
        <di:waypoint x="281" y="523" />
        <di:waypoint x="281" y="818" />
        <di:waypoint x="431" y="818" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
