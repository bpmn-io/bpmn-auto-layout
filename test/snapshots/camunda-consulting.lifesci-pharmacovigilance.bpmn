  <bpmndi:BPMNDiagram id="BPMNDiagram_PV_Agent">
    <bpmndi:BPMNPlane id="BPMNPlane_PV_Agent" bpmnElement="PV_Agent">
      <bpmndi:BPMNShape id="BPMNShape_T_Meddra" bpmnElement="T_Meddra">
