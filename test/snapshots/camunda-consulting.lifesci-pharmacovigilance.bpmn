      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Causality">
    <bpmndi:BPMNPlane id="BPMNPlane_Causality" bpmnElement="Causality">
      <bpmndi:BPMNShape id="BPMNShape_c_s" bpmnElement="c_s">
        <dc:Bounds x="80" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_c_algo" bpmnElement="c_algo">
        <dc:Bounds x="216" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_c_review" bpmnElement="c_review">
        <dc:Bounds x="416" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_c_e" bpmnElement="c_e">
