      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_sla1" bpmnElement="sla1">
        <di:waypoint x="1452" y="968" />
        <di:waypoint x="1452" y="1130" />
        <di:waypoint x="1609" y="1130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="BPMNShape_Pool_Prov" bpmnElement="Pool_Prov" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="882" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Start_R" bpmnElement="Start_R">
        <dc:Bounds x="230" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Submit_PA" bpmnElement="Submit_PA">
        <dc:Bounds x="366" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Send_Records" bpmnElement="Send_Records">
        <dc:Bounds x="566" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Await_Det" bpmnElement="Await_Det">
        <dc:Bounds x="766" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End_R" bpmnElement="End_R">
        <dc:Bounds x="966" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_r1" bpmnElement="r1">
        <di:waypoint x="266" y="140" />
        <di:waypoint x="366" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_r2" bpmnElement="r2">
        <di:waypoint x="466" y="140" />
        <di:waypoint x="566" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_r3" bpmnElement="r3">
        <di:waypoint x="666" y="140" />
        <di:waypoint x="766" y="140" />
