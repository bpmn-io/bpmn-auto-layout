      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gw_Merge" bpmnElement="Gw_Merge" isMarkerVisible="true">
        <dc:Bounds x="1602" y="885" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End_Esc" bpmnElement="End_Esc">
        <dc:Bounds x="1609" y="1112" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1603" y="1153" width="49" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Approve" bpmnElement="Approve">
        <dc:Bounds x="1752" y="1090" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Deny" bpmnElement="Deny">
        <dc:Bounds x="1402" y="1250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Notify_Det" bpmnElement="Notify_Det">
        <dc:Bounds x="1952" y="1090" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_End_P" bpmnElement="End_P">
        <dc:Bounds x="2152" y="1112" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2153" y="1153" width="35" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_MN_Agent" bpmnElement="MN_Agent">
        <dc:Bounds x="1052" y="870" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Peer_Review" bpmnElement="Peer_Review">
        <dc:Bounds x="1402" y="870" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_B_SLA" bpmnElement="B_SLA">
        <dc:Bounds x="1434" y="932" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1363" y="973" width="58" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_p1" bpmnElement="p1">
        <di:waypoint x="266" y="440" />
        <di:waypoint x="366" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_p2" bpmnElement="p2">
        <di:waypoint x="466" y="440" />
        <di:waypoint x="566" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ev_msg" bpmnElement="ev_msg">
        <di:waypoint x="616" y="440" />
        <di:waypoint x="716" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ev_tmr" bpmnElement="ev_tmr">
        <di:waypoint x="591" y="465" />
        <di:waypoint x="591" y="600" />
        <di:waypoint x="716" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ev_c" bpmnElement="ev_c">
        <di:waypoint x="752" y="600" />
        <di:waypoint x="852" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_ev_back" bpmnElement="ev_back">
        <di:waypoint x="952" y="600" />
        <di:waypoint x="1102" y="600" />
        <di:waypoint x="1102" y="870" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_p3" bpmnElement="p3">
        <di:waypoint x="752" y="440" />
        <di:waypoint x="1102" y="440" />
        <di:waypoint x="1102" y="870" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_p4" bpmnElement="p4">
        <di:waypoint x="1152" y="910" />
        <di:waypoint x="1252" y="910" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_d_ok" bpmnElement="d_ok">
