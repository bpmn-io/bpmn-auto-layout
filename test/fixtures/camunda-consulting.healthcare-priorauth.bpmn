        <di:waypoint x="1302" y="910" />
        <di:waypoint x="1402" y="910" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1323" y="854" width="57" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_pr_out" bpmnElement="pr_out">
        <di:waypoint x="1502" y="910" />
        <di:waypoint x="1602" y="910" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_mg1" bpmnElement="mg1">
